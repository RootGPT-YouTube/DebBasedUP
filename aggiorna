#!/bin/bash
#
# aggiorna — Debian-based maintenance & update helper
# by R∞tGPT — original "pipeline" interface (unrelated to Nala)
#
# Engine: apt-get driven through the APT::Status-Fd machine interface, so the
# download/install progress is parsed from a stable frontend protocol instead
# of scraping human-readable text.
#

#== Colors (real ESC, so they work both with printf and echo) ================
RESET=$'\e[0m'
BOLD=$'\e[1m'
DIM=$'\e[38;2;96;106;128m'      # slate-grey for the rules
GREEN=$'\e[38;2;80;220;130m'
RED=$'\e[38;2;255;95;95m'
CYAN=$'\e[38;2;0;220;210m'
GOLD=$'\e[38;2;255;200;90m'

#== Global state =============================================================
steps_ok=0
steps_fail=0
SCRIPT_UPDATE='—'
FIRST_STEP=1

# The TOTAL bar runs on a fixed 0..1000 per-mille scale split into three phase
# bands — download / install / flatpak — weighted 30/40/30 of the whole bar
# (planned up-front in plan_phase). A phase with no work has its weight handed
# to the phases that do, so the bar always spans a full 0→100% with no stalls.
G_TOTAL_PKG=0    # total packages across every section (Cromite excluded) — label only

# Pre-resolved plan (filled by plan_phase)
APT_UPG=0
APT_REM=0
FU_REFS=()       # Flatpak refs to update
FX_REFS=()       # unused Flatpak refs to remove

# Per-mille band boundaries on the TOTAL bar (filled by plan_phase). Each section
# fills its [lo,hi] slice; boundaries are contiguous so the bar never jumps back.
B_DLU_HI=300     # download (APT full-upgrade): 0 .. B_DLU_HI
B_INU_HI=500     # install, upgrade share:      B_DLU_HI .. B_INU_HI
B_INA_HI=700     # install, autoremove:         B_INU_HI .. B_INA_HI
B_FPU_HI=850     # flatpak update share:        B_INA_HI .. B_FPU_HI
                 # flatpak remove share:        B_FPU_HI .. 1000

# Live block bookkeeping
LIVE_DRAWN=0
LIVE_LINES=3
SPIN=('◜' '◠' '◝' '◞' '◡' '◟')   # rotating arc (not braille!)

# Terminal geometry for the fixed TOTAL footer (bottom 2 reserved rows)
TERM_ROWS=24
TERM_COLS=80

#== Utilities ================================================================

# repeat a (possibly multibyte) character n times
rep() { local n=$1 ch=$2 i; for ((i=0; i<n; i++)); do printf '%s' "$ch"; done; }

# write text applying a truecolor gradient from (r1,g1,b1) to (r2,g2,b2)
grad_text() {
    local text="$1" r1=$2 g1=$3 b1=$4 r2=$5 g2=$6 b2=$7
    local len=${#text} i r g b den
    den=$(( len > 1 ? len - 1 : 1 ))
    for ((i=0; i<len; i++)); do
        r=$(( r1 + (r2 - r1) * i / den ))
        g=$(( g1 + (g2 - g1) * i / den ))
        b=$(( b1 + (b2 - b1) * i / den ))
        printf '\e[1m\e[38;2;%d;%d;%dm%s' "$r" "$g" "$b" "${text:i:1}"
    done
    printf '%s' "$RESET"
}

fmt_time() { printf '%02d:%02d' $(( $1 / 60 )) $(( $1 % 60 )); }

kb_to_human() {
    local kb=$1 sign=''
    (( kb < 0 )) && { sign='-'; kb=$(( -kb )); }
    if   (( kb >= 1048576 )); then printf '%s%d.%d GiB' "$sign" $(( kb/1048576 )) $(( (kb%1048576)*10/1048576 ))
    elif (( kb >= 1024    )); then printf '%s%d MiB' "$sign" $(( kb/1024 ))
    else                           printf '%s%d KiB' "$sign" "$kb"
    fi
}

# truncate a string to n columns, appending an ellipsis when it was cut
trunc() {
    local s=$1 n=$2
    if (( ${#s} > n )); then printf '%s…' "${s:0:n-1}"; else printf '%s' "$s"; fi
}

# percentage done/total (0 when total is unknown)
pct() { local d=$1 t=$2; (( t <= 0 )) && { printf '0'; return; }; printf '%d' $(( d * 100 / t )); }

# a [██████░░░░] progress bar of the given width
draw_bar() {
    local d=$1 t=$2 w=$3 fill
    if (( t <= 0 )); then fill=0; else fill=$(( d * w / t )); fi
    (( fill > w )) && fill=$w; (( fill < 0 )) && fill=0
    printf '%s[%s%s%s%s%s]%s' \
        "$DIM" "$CYAN" "$(rep $fill '█')" "$DIM" "$(rep $(( w - fill )) '─')" "$DIM" "$RESET"
}

#== Gradient header ==========================================================
header() {
    local width
    width=$(( TERM_COLS < 56 ? TERM_COLS : 56 ))
    (( width < 24 )) && width=24
    local bar; bar=$(rep $(( width - 4 )) '━')

    echo
    printf '  '; grad_text "$bar" 60 110 200 0 220 210; echo
    printf '   '; grad_text "A G G I O R N A" 70 130 230 0 220 200
    printf '    %s•%s  ' "$DIM" "$RESET"; grad_text "R∞tGPT" 0 220 200 180 90 255
    printf '   %sv4.0%s' "$DIM" "$RESET"; echo
    printf '  '; grad_text "$bar" 0 220 210 60 110 200; echo
    echo
}

#== Fixed TOTAL footer (reserved bottom rows, outside the scroll region) ======
setup_footer() {
    TERM_ROWS=$(tput lines 2>/dev/null || echo 24)
    TERM_COLS=$(tput cols  2>/dev/null || echo 80)
    (( TERM_ROWS < 8 )) && TERM_ROWS=8
    printf '\e[1;%dr' $(( TERM_ROWS - 2 ))     # scroll region: rows 1 .. ROWS-2
    printf '\e[1;1H'                           # cursor back to the top
    draw_total_footer 0
}

teardown_footer() {
    printf '\e7'                               # save the content cursor
    printf '\e[%d;1H\e[K' $(( TERM_ROWS - 1 )) # clear the rule row
    printf '\e[%d;1H\e[K' "$TERM_ROWS"         # clear the bar row
    printf '\e[r'                              # restore full scroll region
    printf '\e8'                               # back to the content cursor
}

# redraw the pinned TOTAL bar; argument = overall progress in per-mille (0..1000)
# on the fixed phase-band scale. Uses absolute positioning + save/restore so it
# never disturbs the scrolling pipeline above it.
draw_total_footer() {
    local pm=$1
    (( pm < 0 )) && pm=0; (( pm > 1000 )) && pm=1000
    local w=$(( TERM_COLS - 34 )); (( w > 40 )) && w=40; (( w < 8 )) && w=8
    printf '\e7'
    printf '\e[%d;1H%s%s%s\e[K' $(( TERM_ROWS - 1 )) "$DIM" "$(rep $(( TERM_COLS > 2 ? TERM_COLS - 2 : 1 )) '─')" "$RESET"
    printf '\e[%d;1H' "$TERM_ROWS"
    printf '   %sTOTAL%s  %s  %s%3s%%%s   %s%d packages%s\e[K' \
        "$BOLD" "$RESET" "$(draw_bar "$pm" 1000 "$w")" \
        "$BOLD" "$(pct "$pm" 1000)" "$RESET" \
        "$DIM" "$G_TOTAL_PKG" "$RESET"
    printf '\e8'
}

#== Pipeline drawing =========================================================

# vertical connector between two pipeline nodes
connector() {
    if (( FIRST_STEP )); then FIRST_STEP=0; else printf '   %s┃%s\n' "$DIM" "$RESET"; fi
}

# redraw the live 3-line block (spinner node + counter + section bar);
# sd/st are the section progress as done/total of any matching scale
render_live() {
    local spin=$1 label=$2 el=$3 counter=$4 sd=$5 st=$6
    (( LIVE_DRAWN )) && printf '\e[%dA' "$LIVE_LINES"
    LIVE_DRAWN=1
    printf '\r   %s%s%s  %s   %s%s%s\e[K\n' "$CYAN" "$spin" "$RESET" "$label" "$DIM" "$el" "$RESET"
    printf '\r      %s%s%s\e[K\n' "$DIM" "$counter" "$RESET"
    printf '\r      %ssection%s %s %s%3s%%%s\e[K\n' "$DIM" "$RESET" "$(draw_bar "$sd" "$st" 22)" "$DIM" "$(pct "$sd" "$st")" "$RESET"
}

# collapse the live block into a single result node line
finish_node() {
    local sym=$1 color=$2 label=$3
    (( LIVE_DRAWN )) && printf '\e[%dA' "$LIVE_LINES"
    printf '\r   %s%s%s  %s\e[K\n' "$color" "$sym" "$RESET" "$label"
    (( LIVE_DRAWN )) && printf '\e[J'
    LIVE_DRAWN=0
}

# error box with the tail of the command log
error_box() {
    local log=$1
    printf '   %s┃%s\n' "$DIM" "$RESET"
    printf '   %s┗━ error detail ─────────────────────────────%s\n' "$RED" "$RESET"
    tail -n 8 "$log" | sed "s/^/      ${DIM}│${RESET} /"
    printf '   %s──────────────────────────────────────────────%s\n' "$RED" "$RESET"
}

#== Plain spinner step (no per-package progress: e.g. cromup) =================
run_step() {
    local label="$1"; shift
    local log; log=$(mktemp)
    connector
    "$@" >"$log" 2>&1 &
    local pid=$! i=0 start=$SECONDS
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r   %s%s%s  %s   %s%s%s\e[K' \
            "$CYAN" "${SPIN[i%6]}" "$RESET" "$label" "$DIM" "$(fmt_time $(( SECONDS - start )))" "$RESET"
        i=$(( i + 1 )); sleep 0.12
    done
    wait "$pid"; local rc=$?
    if (( rc == 0 )); then
        printf '\r   %s●%s  %s\e[K\n' "$GREEN" "$RESET" "$label"
        steps_ok=$(( steps_ok + 1 ))
    else
        printf '\r   %s✗%s  %s%s%s\e[K\n' "$RED" "$RESET" "$RED" "$label" "$RESET"
        steps_fail=$(( steps_fail + 1 ))
        error_box "$log"
    fi
    rm -f "$log"
}

#== Planning: resolve every section up-front so the TOTAL is known ============

# sum a field from an "apt-get -s" summary line, e.g.
#   "1 upgraded, 1 newly installed, 0 to remove and 0 not upgraded."
# field=install -> upgraded + newly installed ; field=remove -> to remove
apt_count() {
    local field="$1"; shift
    "$@" 2>/dev/null | awk -v f="$field" '
        / upgraded/ && /installed/ {
            gsub(/[,.]/, "")
            for (i = 1; i <= NF; i++) {
                if ($i == "upgraded" && up == "") up = $(i-1)
                else if ($i == "newly")          ni = $(i-1)
                else if ($i == "to")             rm = $(i-1)
            }
        }
        END { if (f == "install") print up + ni + 0; else print rm + 0 }'
}

# list Flatpak refs needing an update (mode=update) or that are unused (mode=unused)
flatpak_refs() {
    if [[ $1 == update ]]; then
        env LC_ALL=C flatpak update --no-deploy 2>/dev/null
    else
        printf 'n\n' | env LC_ALL=C flatpak uninstall --unused 2>/dev/null
    fi | awk -F'\t' '/^[[:space:]]*[0-9]+\./ { gsub(/^[ \t]+|[ \t]+$/,"",$3); if ($3!="") print $3 }'
}

plan_phase() {
    connector
    local tmp; tmp=$(mktemp)
    (
        # one metadata refresh; the upgrade below reuses these lists
        sudo env LC_ALL=C apt-get update >/dev/null 2>&1
        upg=$(apt_count install sudo env LC_ALL=C apt-get -s full-upgrade)
        rem=$(apt_count remove  sudo env LC_ALL=C apt-get -s autoremove)
        mapfile -t fu < <(flatpak_refs update)
        mapfile -t fx < <(flatpak_refs unused)
        {
            printf 'P_UPG=%d\n'  "${upg:-0}"
            printf 'P_REM=%d\n'  "${rem:-0}"
            printf 'FU=%s\n' "$(printf '%s\n' "${fu[@]}")"
            printf '__FUEND__\n'
            printf 'FX=%s\n' "$(printf '%s\n' "${fx[@]}")"
            printf '__FXEND__\n'
        } > "$tmp"
    ) &
    local pid=$! i=0 start=$SECONDS
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r   %s%s%s  %s   %s%s%s\e[K' \
            "$CYAN" "${SPIN[i%6]}" "$RESET" "Planning updates" "$DIM" "$(fmt_time $(( SECONDS - start )))" "$RESET"
        i=$(( i + 1 )); sleep 0.12
    done
    wait "$pid"

    # parse the plan
    APT_UPG=$(sed -n 's/^P_UPG=//p' "$tmp"); APT_UPG=${APT_UPG:-0}
    APT_REM=$(sed -n 's/^P_REM=//p' "$tmp"); APT_REM=${APT_REM:-0}
    mapfile -t FU_REFS < <(sed -n '/^FU=/,/^__FUEND__$/p' "$tmp" | sed '1s/^FU=//; /^__FUEND__$/d; /^$/d')
    mapfile -t FX_REFS < <(sed -n '/^FX=/,/^__FXEND__$/p' "$tmp" | sed '1s/^FX=//; /^__FXEND__$/d; /^$/d')
    rm -f "$tmp"

    local nfu=${#FU_REFS[@]} nfx=${#FX_REFS[@]}
    G_TOTAL_PKG=$(( APT_UPG + APT_REM + nfu + nfx ))

    # Carve the 0..1000 bar into download / install / flatpak bands, weighted
    # 30/40/30 — but a phase with no work hands its weight to the others, so the
    # present phases always stretch to fill the whole bar.
    local in_tot=$(( APT_UPG + APT_REM )) fp_tot=$(( nfu + nfx ))
    local wdl=0 win=0 wfp=0
    (( APT_UPG > 0 )) && wdl=30
    (( in_tot  > 0 )) && win=40
    (( fp_tot  > 0 )) && wfp=30
    local w=$(( wdl + win + wfp )); (( w == 0 )) && w=1

    B_DLU_HI=$(( 1000 * wdl / w ))                         # end of download band
    local in_lo=$B_DLU_HI in_span=$(( 1000 * win / w ))
    local in_hi=$(( in_lo + in_span ))
    # split the install band between upgrade and autoremove by package count
    B_INU_HI=$(( in_tot > 0 ? in_lo + in_span * APT_UPG / in_tot : in_lo ))
    B_INA_HI=$in_hi
    # the flatpak band is everything left up to 1000, split update vs remove
    local fp_lo=$in_hi
    B_FPU_HI=$(( fp_tot > 0 ? fp_lo + (1000 - fp_lo) * nfu / fp_tot : fp_lo ))

    draw_total_footer 0
    printf '\r   %s●%s  Planning complete  %s(%d package(s) to process)%s\e[K\n' \
        "$GREEN" "$RESET" "$DIM" "$G_TOTAL_PKG" "$RESET"
}

#== APT step with download + transaction progress ============================
# run_apt "Label" "Install|Remove" pkgcount dl_lo dl_hi in_lo in_hi sudo env ... apt-get -y <cmd>
#
# The download phase fills the TOTAL bar's [dl_lo,dl_hi] band, the transaction
# fills [in_lo,in_hi]; dl_lo==dl_hi means "this step never downloads".
#
# We append APT::Status-Fd=1 so apt writes machine-readable status lines
#   dlstatus:<id>:<pct>:<msg>      (overall download percentage)
#   pmstatus:<pkg>:<pct>:<msg>     (overall install percentage)
# onto stdout, interleaved with its normal text. The status lines drive the
# bars; everything else is funnelled to the log for the error box. Status goes
# to fd 1 (not a higher fd) because sudo closes inherited descriptors >= 3.
run_apt() {
    local label="$1" p2="$2" pkg="$3" dl_lo="$4" dl_hi="$5" in_lo="$6" in_hi="$7"; shift 7
    local log; log=$(mktemp)
    connector

    if (( pkg == 0 )); then
        render_live "${SPIN[0]}" "$label" '00:00' 'nothing to do' 1 1
        draw_total_footer "$in_hi"
        finish_node '●' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 )); rm -f "$log"; return
    fi

    local dl_pct=0 in_pct=0 saw_dl=0 installing=0
    local counter='resolving…' inname='' dlname=''
    local start=$SECONDS i=0 rc=-1 fd
    exec {fd}< <( { "$@" -o APT::Status-Fd=1 2>>"$log"; printf '\n__RC__%d__\n' "$?"; } )

    render_live "${SPIN[0]}" "$label" '00:00' "$counter" 0 1
    draw_total_footer "$dl_lo"

    while true; do
        if IFS= read -t 0.12 -r -u "$fd" line; then
            case "$line" in
                __RC__*__)
                    rc=${line#__RC__}; rc=${rc%__}; continue
                    ;;
                dlstatus:*)
                    local rest=${line#dlstatus:}; rest=${rest#*:}   # drop the id
                    local p=${rest%%:*} msg=${rest#*:}
                    p=${p%%.*}; saw_dl=1; dl_pct=${p:-0}
                    dlname=$(trunc "$msg" 42)
                    counter="Downloading ${dl_pct}%  ${dlname}"
                    ;;
                pmstatus:*)
                    local rest=${line#pmstatus:}
                    local pk=${rest%%:*}; rest=${rest#*:}
                    local p=${rest%%:*} msg=${rest#*:}
                    p=${p%%.*}; installing=1; in_pct=${p:-0}
                    [[ $pk == dpkg* || -z $pk ]] || inname=$pk
                    counter="$p2 ${in_pct}%  ${inname:-$(trunc "$msg" 42)}"
                    ;;
                *)
                    printf '%s\n' "$line" >>"$log"
                    ;;
            esac
        else
            (( $? > 128 )) || break
        fi
        # section bar (download = first half, install = second half) and the
        # absolute TOTAL position within this step's two bands
        local f=0 pm=$dl_lo
        if (( installing )); then
            f=$(( saw_dl ? 500 + in_pct * 5 : in_pct * 10 ))
            pm=$(( in_lo + (in_hi - in_lo) * in_pct / 100 ))
        elif (( saw_dl )); then
            f=$(( dl_pct * 5 ))
            pm=$(( dl_lo + (dl_hi - dl_lo) * dl_pct / 100 ))
        fi
        (( f > 1000 )) && f=1000
        render_live "${SPIN[i%6]}" "$label" "$(fmt_time $(( SECONDS - start )))" "$counter" "$f" 1000
        draw_total_footer "$pm"
        i=$(( i + 1 ))
    done
    exec {fd}<&-

    draw_total_footer "$in_hi"
    if (( rc == 0 )); then
        finish_node '●' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 ))
    else
        finish_node '✗' "$RED" "$label"; steps_fail=$(( steps_fail + 1 )); error_box "$log"
    fi
    rm -f "$log"
}

#== Flatpak section: update or remove one ref at a time ======================
# run_flatpak "Label" update|remove lo hi ref...
# Fills the TOTAL bar's [lo,hi] band as the refs complete.
run_flatpak() {
    local label="$1" mode="$2" lo="$3" hi="$4"; shift 4
    local refs=("$@") N=$#
    local log; log=$(mktemp)
    connector

    local verb; [[ $mode == update ]] && verb=Update || verb=Remove

    if (( N == 0 )); then
        render_live "${SPIN[0]}" "$label" '00:00' 'nothing to do' 1 1
        draw_total_footer "$hi"
        finish_node '●' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 )); rm -f "$log"; return
    fi

    local rc=0 start=$SECONDS i=0 idx=0 ref
    for ref in "${refs[@]}"; do
        idx=$(( idx + 1 ))
        local cur_pct=0 lrc=0 fd
        if [[ $mode == update ]]; then
            exec {fd}< <( { env LC_ALL=C flatpak update -y "$ref"; printf '\n__RC__%d__\n' "$?"; } 2>&1 )
        else
            exec {fd}< <( { env LC_ALL=C flatpak uninstall -y "$ref"; printf '\n__RC__%d__\n' "$?"; } 2>&1 )
        fi
        while true; do
            if IFS= read -t 0.12 -r -u "$fd" line; then
                case "$line" in __RC__*__) lrc=${line#__RC__}; lrc=${lrc%__}; continue;; esac
                printf '%s\n' "$line" >>"$log"
                [[ $line =~ ([0-9]+)%[^0-9]*$ ]] && cur_pct=${BASH_REMATCH[1]}
            else
                (( $? > 128 )) || break
            fi
            local sd=$(( (idx - 1) * 1000 + cur_pct * 10 ))
            render_live "${SPIN[i%6]}" "$label" "$(fmt_time $(( SECONDS - start )))" \
                "$verb $idx/$N: $ref" "$sd" "$(( N * 1000 ))"
            draw_total_footer $(( lo + (hi - lo) * sd / (N * 1000) ))
            i=$(( i + 1 ))
        done
        exec {fd}<&-
        (( lrc != 0 )) && rc=1
    done

    draw_total_footer "$hi"
    if (( rc == 0 )); then
        finish_node '●' "$GREEN" "$label"; steps_ok=$(( steps_ok + 1 ))
    else
        finish_node '✗' "$RED" "$label"; steps_fail=$(( steps_fail + 1 )); error_box "$log"
    fi
    rm -f "$log"
}

#== Report card =============================================================
card_line() {
    local label="$1" value="$2" vcolor="$3"
    local inner=46
    local left="  ${label}"
    local pad=$(( inner - ${#left} - ${#value} - 2 ))
    (( pad < 1 )) && pad=1
    printf '  %s│%s%s%*s%s%s%s  %s│%s\n' \
        "$CYAN" "$RESET" "$left" "$pad" '' "$vcolor" "$value" "$RESET" "$CYAN" "$RESET"
}

report_card() {
    local inner=46
    local rule; rule=$(rep "$inner" '─')
    local title='R E P O R T'
    local tpad=$(( (inner - ${#title}) / 2 ))

    echo
    printf '  %s╭%s╮%s\n' "$CYAN" "$rule" "$RESET"
    printf '  %s│%s%*s%s%s%s%*s%s│%s\n' \
        "$CYAN" "$RESET" "$tpad" '' "$GOLD$BOLD" "$title" "$RESET" \
        $(( inner - tpad - ${#title} )) '' "$CYAN" "$RESET"
    printf '  %s├%s┤%s\n' "$CYAN" "$rule" "$RESET"

    local ok_color="$GREEN"; (( steps_fail > 0 )) && ok_color="$GOLD"
    card_line "Operations succeeded" "${steps_ok}/$(( steps_ok + steps_fail ))" "$ok_color$BOLD"
    card_line "Packages processed"   "${G_TOTAL_PKG}"                            "$BOLD"
    card_line "Time elapsed"         "$(fmt_time "$SECONDS")"                     "$BOLD"
    local freed=$(( END_AVAIL - START_AVAIL ))
    if (( freed >= 0 )); then
        card_line "Space freed"  "$(kb_to_human "$freed")"   "$GREEN$BOLD"
    else
        card_line "Space used"   "$(kb_to_human "$(( -freed ))")" "$GOLD$BOLD"
    fi
    card_line "Script update" "$SCRIPT_UPDATE"            "$BOLD"

    printf '  %s╰%s╯%s\n' "$CYAN" "$rule" "$RESET"
    echo
}

#== Cleanup: reset the scroll region, restore the cursor, stop sudo keep-alive =
cleanup() {
    printf '\e[r'                                      # reset the scroll region
    printf '\e[?25h'                                   # show the cursor again
    [ -n "${SUDO_PID:-}" ] && kill "$SUDO_PID" 2>/dev/null
}
trap cleanup EXIT INT TERM

#== START ===================================================================
clear
setup_footer
header

# Root credentials + keep-alive (steps read package-manager output through a
# pipe, so sudo must never stop to ask for the password mid-run)
printf '   %s🔑 Administrator authentication required...%s\n\n' "$GOLD" "$RESET"
if ! sudo -v; then
    printf '   %s✗ Authentication failed. Exiting.%s\n' "$RED" "$RESET"
    exit 1
fi
( while true; do sudo -n true; sleep 50; kill -0 "$$" 2>/dev/null || exit; done ) 2>/dev/null &
SUDO_PID=$!

printf '\e[?25l'                                        # hide the cursor
START_AVAIL=$(df --output=avail / | tail -1 | tr -d ' ')

# Resolve everything first (one metadata refresh), so the TOTAL bar is exact.
plan_phase

# The upgrade reuses the lists just refreshed during planning (no second update).
# DEBIAN_FRONTEND=noninteractive keeps dpkg from stopping on conffile prompts.
# Each step is handed its slice of the TOTAL bar computed in plan_phase.
run_apt      "System upgrade (APT)"        "Install" "$APT_UPG" 0          "$B_DLU_HI" "$B_DLU_HI" "$B_INU_HI" \
    sudo env LC_ALL=C DEBIAN_FRONTEND=noninteractive apt-get -y -q -o Dpkg::Use-Pty=0 full-upgrade
run_apt      "Removing orphaned packages"  "Remove"  "$APT_REM" "$B_INU_HI" "$B_INU_HI" "$B_INU_HI" "$B_INA_HI" \
    sudo env LC_ALL=C DEBIAN_FRONTEND=noninteractive apt-get -y -q -o Dpkg::Use-Pty=0 autoremove
run_flatpak  "Updating Flatpaks"           update "$B_INA_HI" "$B_FPU_HI" "${FU_REFS[@]}"
run_flatpak  "Removing unused Flatpaks"    remove "$B_FPU_HI" 1000         "${FX_REFS[@]}"

# Optional hook: cromup (Cromite) — excluded from the overall progress bar
if [ -x /usr/local/bin/cromup ]; then
    run_step "Updating Cromite (cromup)" cromup
fi

END_AVAIL=$(df --output=avail / | tail -1 | tr -d ' ')
teardown_footer

#== Script self-update ======================================================
if curl -fsSL https://raw.githubusercontent.com/RootGPT-YouTube/DebBasedUP/main/aggiorna -o /tmp/aggiorna.tmp 2>/dev/null; then
    if ! cmp -s /tmp/aggiorna.tmp /usr/local/bin/aggiorna 2>/dev/null; then
        if sudo mv /tmp/aggiorna.tmp /usr/local/bin/aggiorna && sudo chmod a+x /usr/local/bin/aggiorna; then
            SCRIPT_UPDATE='updated ✓'
        else
            SCRIPT_UPDATE='error ✗'
        fi
    else
        SCRIPT_UPDATE='already up to date'
        rm -f /tmp/aggiorna.tmp
    fi
else
    rm -f /tmp/aggiorna.tmp
    SCRIPT_UPDATE='not checked'
fi

#== Report + exit ===========================================================
report_card
printf '\e[?25h'
read -r -p "$(printf '   %s↵ Press ENTER to close%s' "$DIM" "$RESET")"
clear
# == End of script ==
